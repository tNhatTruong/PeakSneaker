{
  "name": "peaksneaker-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:up && concurrently -c \"cyan,magenta\" -n \"BACKEND,FRONTEND\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:up": "cd infra && docker-compose up -d",
    "dev:backend": "cd backend && gradlew bootRun",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
